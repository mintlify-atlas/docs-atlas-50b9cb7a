  "publicApiSurface": [
    "MainActivity - Main app entry point",
    "MusicService - Background playback service (MediaSessionService)",
    "ExoDownloadService - Download management service",
    "MusicWidgetProvider - Home screen widget",
    "FindWidgetProvider - Find widget",
    "VideoPlayerActivity - Video playback screen",
    "CastOptionsProvider - Chromecast configuration",
    "DLNA/UPnP streaming capabilities",
    "YouTube Music integration via InnerTube API",
    "Lyrics providers (LRCLIB, Kugou)"
