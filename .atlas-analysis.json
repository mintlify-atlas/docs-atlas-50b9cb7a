  "keyFeatures": [
    "Ad-free YouTube Music streaming",
    "Offline downloads with dedicated download manager",
    "Real-time synchronized lyrics with AI translation",
    "Audio recognition for song identification",
    "DLNA/UPnP casting to network devices",
    "Chromecast support",
    "Sleep timer with fade out",
    "Background and lockscreen playback",
